# Configuracion de AppWeb
# Copia este archivo a .env
# cp .env.example .env

# URL base del backend Laravel para la web.
# Debe apuntar a /api (sin /v1) porque la app usa rutas como /v1/auth/login.
#
# Ejemplos:
# Local (misma PC):      http://localhost:8000/api
# Red local:             http://192.168.1.50:8000/api
# Produccion:            https://api.tudominio.com/api

VITE_API_BASE_URL=http://localhost:8000/api

