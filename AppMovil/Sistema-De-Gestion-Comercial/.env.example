# ==========================================================
# Configuración de la App Móvil SDGC
# ==========================================================
# Copia este archivo como .env y ajusta los valores.
#
# IMPORTANTE: Nunca subas el archivo .env al repositorio.
# ==========================================================

# URL base de la API del backend Laravel.
# Ajustar según el entorno:
#
#   Expo Web (misma PC):     http://localhost:8000/api/v1
#   Emulador Android:        http://10.0.2.2:8000/api/v1
#   Simulador iOS:           http://localhost:8000/api/v1
#   Dispositivo físico:      http://<IP_PC>:8000/api/v1
#   Producción:              https://api.midominio.com/v1
#
# Nota: La app remapea automáticamente localhost→10.0.2.2
# en Android, así que puedes dejar localhost en casi todos los casos.

EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
